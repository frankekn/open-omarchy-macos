#!/bin/zsh
set -euo pipefail

editor="${EDITOR:-/opt/homebrew/bin/nvim}"
agent="${TMUX_DEV_AGENT:-opencode}"
target_pane="$(tmux display-message -p '#{pane_id}')"

pane_path="${OPEN_OMARCHY_PROJECT_PATH:-$(tmux display-message -p -t "$target_pane" '#{pane_current_path}')}"

# Normalize to git root so Ctrl-C lands in the project, not a nested subfolder.
git_root="$(git -C "$pane_path" rev-parse --show-toplevel 2>/dev/null || true)"
if [[ -n "$git_root" ]]; then
  pane_path="$git_root"
fi

window_name="$(basename "$pane_path")"

new_pane="$(tmux new-window -c "$pane_path" -n "$window_name" -P -F '#{pane_id}')"
agent_pane="$(tmux split-window -h -p 40 -t "$new_pane" -c "$pane_path" -P -F '#{pane_id}')"

# Explicit cd in each pane so the shell's own cwd is the project root.
# Without this, Ctrl-C from the agent drops back to wherever the pane was spawned.
tmux send-keys -t "$new_pane"   C-c C-u "cd \"$pane_path\" && $editor ." C-m
tmux send-keys -t "$agent_pane" C-c C-u "cd \"$pane_path\" && $agent" C-m
tmux select-pane -t "$new_pane"

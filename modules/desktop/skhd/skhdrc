#!/usr/bin/env sh

# open-omarchy-macos skhd config
# Omarchy-inspired bindings adapted for macOS conflicts.
# NOTE: Avoid cmd+q to preserve native macOS quit behavior.

# Applications
cmd - return : open -na Ghostty 2>/dev/null || open -na Terminal
cmd - space : open -na Raycast 2>/dev/null || osascript -e 'tell application "System Events" to keystroke space using command down'

# Focus
# F13-F16 are private window-manager keys intended to be emitted by a
# Karabiner Caps layer, e.g. Caps+h/j/k/l -> F13/F14/F15/F16.
f13 : yabai -m window --focus west
f14 : yabai -m window --focus south
f15 : yabai -m window --focus north
f16 : yabai -m window --focus east

# Swap
cmd + shift - h : yabai -m window --swap west
cmd + shift - j : yabai -m window --swap south
cmd + shift - k : yabai -m window --swap north
cmd + shift - l : yabai -m window --swap east

# Window control
cmd + shift - q : yabai -m window --close
cmd - f : yabai -m window --toggle zoom-fullscreen
cmd + shift - space : yabai -m window --toggle float

# Resize (grow toward direction by 30px)
cmd + alt + shift - h : yabai -m window --resize left:-30:0
cmd + alt + shift - j : yabai -m window --resize bottom:0:30
cmd + alt + shift - k : yabai -m window --resize top:0:-30
cmd + alt + shift - l : yabai -m window --resize right:30:0

# Space focus (cmd + ctrl + N). cmd + N is left untouched so app-internal
# tab switching keeps working in Chrome/Safari/Ghostty/VS Code/Slack/etc.
cmd + ctrl - 1 : yabai -m space --focus 1
cmd + ctrl - 2 : yabai -m space --focus 2
cmd + ctrl - 3 : yabai -m space --focus 3
cmd + ctrl - 4 : yabai -m space --focus 4
cmd + ctrl - 5 : yabai -m space --focus 5
cmd + ctrl - 6 : yabai -m space --focus 6
cmd + ctrl - 7 : yabai -m space --focus 7
cmd + ctrl - 8 : yabai -m space --focus 8
cmd + ctrl - 9 : yabai -m space --focus 9

# Move focused window to Space N and follow it (cmd + shift + ctrl + N).
# Mirrors cmd + ctrl + N (focus). yabai v7+ supports this without the
# scripting addition on Apple Silicon.
cmd + shift + ctrl - 1 : yabai -m window --space 1 && yabai -m space --focus 1
cmd + shift + ctrl - 2 : yabai -m window --space 2 && yabai -m space --focus 2
cmd + shift + ctrl - 3 : yabai -m window --space 3 && yabai -m space --focus 3
cmd + shift + ctrl - 4 : yabai -m window --space 4 && yabai -m space --focus 4
cmd + shift + ctrl - 5 : yabai -m window --space 5 && yabai -m space --focus 5
cmd + shift + ctrl - 6 : yabai -m window --space 6 && yabai -m space --focus 6
cmd + shift + ctrl - 7 : yabai -m window --space 7 && yabai -m space --focus 7
cmd + shift + ctrl - 8 : yabai -m window --space 8 && yabai -m space --focus 8
cmd + shift + ctrl - 9 : yabai -m window --space 9 && yabai -m space --focus 9

# Display focus
cmd + alt - h : yabai -m display --focus west
cmd + alt - j : yabai -m display --focus south
cmd + alt - k : yabai -m display --focus north
cmd + alt - l : yabai -m display --focus east

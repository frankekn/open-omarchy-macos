#!/usr/bin/env bash
# open-omarchy — workspace distro CLI
# Usage: open-omarchy <command> [options]

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
REPO_DIR="$(cd "$SCRIPT_DIR/.." && pwd)"
if [ ! -d "${REPO_DIR}/scripts" ]; then
  REPO_POINTER="${HOME}/.config/open-omarchy-macos/repo-path"
  if [ -f "$REPO_POINTER" ]; then
    REPO_DIR="$(cat "$REPO_POINTER")"
  fi
fi

if [ ! -d "${REPO_DIR}/scripts" ]; then
  echo "[open-omarchy] ERROR: repo scripts not found." >&2
  echo "[open-omarchy] Reinstall from the repo, or set ${HOME}/.config/open-omarchy-macos/repo-path." >&2
  exit 1
fi

SCRIPTS_DIR="${REPO_DIR}/scripts"

# shellcheck source=scripts/lib/config.sh
source "${SCRIPTS_DIR}/lib/config.sh"

usage() {
  cat >&2 <<EOF
Usage: open-omarchy <command> [options]

Commands:
  install   Install modules to this machine
  revert    Restore previous state from backup manifest
  status    Show current setup state
  doctor    Check dependencies and config validity
  work      Attach to (or create) the Work tmux session
  project   Open a project window via fzf picker
  palette   Open the tmux command palette

Options:
  install --module <name>    Target module (desktop | tmux | nvim | terminal | shell)
  --dry-run          Print actions without making changes

Run 'open-omarchy <command> --help' for command-specific help.
EOF
  exit 1
}

cmd_install() {
  exec "$SCRIPTS_DIR/install.sh" "$@"
}

cmd_revert() {
  exec "$SCRIPTS_DIR/revert.sh" "$@"
}

cmd_status() {
  exec "$SCRIPTS_DIR/status.sh" "$@"
}

cmd_doctor() {
  exec "$SCRIPTS_DIR/doctor.sh" "$@"
}

cmd_work() {
  local config_file="${HOME}/.config/open-omarchy-macos/config.toml"
  local session_name
  session_name="$(config_get session_name "$config_file" Work)"

  if tmux has-session -t "$session_name" 2>/dev/null; then
    if [ -n "${TMUX:-}" ]; then
      tmux switch-client -t "$session_name"
    else
      tmux attach-session -t "$session_name"
    fi
  else
    tmux new-session -s "$session_name"
  fi
}

cmd_project() {
  # Delegate to the project-window script if tmux module is installed
  local project_bin="${HOME}/.local/bin/open-omarchy-project-window"
  local fallback_bin="${HOME}/.local/bin/tmux-project-window"

  if [ -x "$project_bin" ]; then
    exec "$project_bin" "$@"
  elif [ -x "$fallback_bin" ]; then
    exec "$fallback_bin" "$@"
  else
    echo "[open-omarchy] open-omarchy-project-window not found." >&2
    echo "Run: open-omarchy install --module tmux" >&2
    exit 1
  fi
}

cmd_palette() {
  local palette_bin="${HOME}/.local/bin/open-omarchy-command-palette"

  if [ -x "$palette_bin" ]; then
    exec "$palette_bin" "$@"
  else
    echo "[open-omarchy] open-omarchy-command-palette not found." >&2
    echo "Run: open-omarchy install --module tmux" >&2
    exit 1
  fi
}

[ $# -eq 0 ] && usage

COMMAND="$1"
shift

case "$COMMAND" in
  install)  cmd_install  "$@" ;;
  revert)   cmd_revert   "$@" ;;
  status)   cmd_status   "$@" ;;
  doctor)   cmd_doctor   "$@" ;;
  work)     cmd_work     "$@" ;;
  project)  cmd_project  "$@" ;;
  palette)  cmd_palette  "$@" ;;
  -h|--help|help) usage ;;
  *) echo "[open-omarchy] Unknown command: $COMMAND" >&2; usage ;;
esac
